    <property name="styleSheet">
     <string notr="true">#btnSave {
    background-color: #8c1515; /* 经典的北大红背景 */
    color: white;              /* 白色文字 */
    border-radius: 12px;       /* 圆角效果，数值越大越圆润 */
    font-size: 16px;           /* 字体放大 */
    font-weight: bold;         /* 字体加粗 */
}

/* 鼠标悬停在按钮上时，颜色稍微变深一点，增加交互感 */
#btnSave:hover {
    background-color: #a01a1a;
}

/* 鼠标点下去的一瞬间，按钮往下沉一下 */
#btnSave:pressed {
    background-color: #701010;
    padding-top: 2px;
    padding-left: 2px;
}</string>
    </property>
